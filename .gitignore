# Files generated by invoking Julia with --code-coverage
*.jl.cov
*.jl.*.cov

# Files generated by invoking Julia with --track-allocation
*.jl.mem

# Build artifacts generated by the Documenter package (package is nested, so match at any depth)
**/docs/build/
**/docs/site/

# Manifests: gitignored for packages (records a fixed state; committed only for applications)
**/Manifest*.toml

# Local preferences
**/LocalPreferences.toml
**/JuliaLocalPreferences.toml

# Editor / OS cruft
.DS_Store
*.swp
